---
import Layout from '../../components/layout/Layout.astro';

export function getStaticPaths() {
  return Array.from({ length: 50 }, (_, i) => ({ params: { id: String(i + 1) } }));
}

const { id } = Astro.params;
---

<Layout title="공지사항 - 대치프라임" description="대치프라임 공지사항">
  <div class="min-h-screen bg-white">
    <div class="container mx-auto px-4 py-12 max-w-3xl">

      <!-- 로딩 -->
      <div id="loading" class="py-24 text-center text-gray-400 text-sm">불러오는 중...</div>

      <!-- 공지 내용 -->
      <div id="notice-content" class="hidden">
        <div class="mb-8">
          <a href="/notice" class="text-sm text-gray-400 hover:text-brand transition-colors">← 목록으로</a>
        </div>

        <h1 id="notice-title" class="text-2xl font-bold text-gray-900 mb-4"></h1>

        <div class="flex items-center gap-4 text-sm text-gray-400 pb-6 border-b border-gray-200 mb-8">
          <span id="notice-date"></span>
          <span>조회수 <span id="notice-views"></span></span>
        </div>

        <div id="notice-image-wrap" class="hidden mb-8">
          <img id="notice-image" src="" alt="" class="w-full rounded-xl border border-gray-100 object-contain max-h-[500px]" />
        </div>
        <div id="notice-body" class="text-gray-700 leading-relaxed whitespace-pre-wrap min-h-[200px]"></div>

        <div class="mt-12 pt-6 border-t border-gray-200 text-center">
          <a href="/notice" class="inline-block border border-gray-300 text-gray-600 text-sm font-medium px-8 py-3 rounded-lg hover:bg-gray-50 transition-colors">
            목록으로
          </a>
        </div>
      </div>

      <!-- 에러 -->
      <div id="notice-error" class="hidden py-24 text-center text-gray-400 text-sm">
        공지사항을 찾을 수 없습니다.
        <div class="mt-4">
          <a href="/notice" class="text-brand hover:underline">목록으로 돌아가기</a>
        </div>
      </div>

    </div>
  </div>
</Layout>

<script>
  import { supabase } from '../../lib/supabase';

  async function load() {
    const id = location.pathname.split('/').pop();

    const { data, error } = await supabase
      .from('notices')
      .select('*')
      .eq('id', id)
      .single();

    document.getElementById('loading')?.classList.add('hidden');

    if (error || !data) {
      document.getElementById('notice-error')?.classList.remove('hidden');
      return;
    }

    await supabase.from('notices').update({ views: (data.views ?? 0) + 1 }).eq('id', id);

    document.getElementById('notice-title')!.textContent = data.title;
    document.getElementById('notice-date')!.textContent = new Date(data.created_at)
      .toLocaleDateString('ko-KR', { year: 'numeric', month: '2-digit', day: '2-digit' });
    document.getElementById('notice-views')!.textContent = ((data.views ?? 0) + 1).toLocaleString();
    document.getElementById('notice-body')!.textContent = data.content ?? '내용이 없습니다.';
    if (data.image_url) {
      const img = document.getElementById('notice-image') as HTMLImageElement;
      img.src = data.image_url;
      document.getElementById('notice-image-wrap')?.classList.remove('hidden');
    }
    document.getElementById('notice-content')?.classList.remove('hidden');
    document.title = `${data.title} - 대치프라임`;
  }

  document.addEventListener('astro:page-load', load);
</script>
