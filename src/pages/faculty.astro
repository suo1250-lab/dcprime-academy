---
import Layout from '../components/layout/Layout.astro';

const subjects = ['전체', '수학', '영어', '과학', '국어', '탐독'];

const faculty = [
  // 수학 (ㄱ~ㅎ)
  { subject: '수학', name: '김경우', image: '/images/faculty/math-김경우.jpg', motto: '포기하지 않는 학생 곁에 끝까지 함께합니다.' },
  { subject: '수학', name: '김성환', image: '/images/faculty/math-김성환.jpg', motto: '수학의 원리를 깨달으면 두려움이 사라집니다.' },
  { subject: '수학', name: '나정환', image: '/images/faculty/math-나정환.jpg', motto: '한 문제 한 문제가 실력이 됩니다.' },
  { subject: '수학', name: '박명신', image: '/images/faculty/math-박명신.jpg', motto: '작은 성취가 쌓여 큰 자신감이 됩니다.' },
  { subject: '수학', name: '박주원', image: '/images/faculty/math-박주원.jpg', motto: '기초부터 탄탄하게, 함께 올라가겠습니다.' },
  { subject: '수학', name: '이재원', image: '/images/faculty/math-이재원.jpg', motto: '틀린 문제에서 실력이 자랍니다.' },
  { subject: '수학', name: '이희승', image: '/images/faculty/math-이희승.jpg', motto: '이해 없는 암기는 없습니다.' },
  { subject: '수학', name: '조해공', image: '/images/faculty/math-조해공.jpg', motto: '정확한 개념이 최고의 무기입니다.' },
  { subject: '수학', name: '함성훈', image: '/images/faculty/math-함성훈.jpg', motto: '꾸준함이 재능을 이깁니다.' },
  { subject: '수학', name: '허선영', image: '/images/faculty/math-허선영.jpg', motto: '모든 학생에게 맞는 풀이법이 있습니다.' },
  // 영어
  { subject: '영어', name: '양승경', image: '/images/faculty/eng-양승경.jpg', motto: '영어는 도구입니다. 자신있게 쓰게 합니다.' },
  { subject: '영어', name: '양윤정', image: '/images/faculty/eng-양윤정.jpg', motto: '읽고 듣고 쓰는 힘을 함께 키웁니다.' },
  { subject: '영어', name: '이소희', image: '/images/faculty/eng-이소희.jpg', motto: '점수도 실력도, 함께 올립니다.' },
  { subject: '영어', name: '이정헌', image: '/images/faculty/eng-이정헌.jpg', motto: '문법의 틀 위에 독해를 쌓습니다.' },
  { subject: '영어', name: '정다운', image: '/images/faculty/eng-정다운.jpg', motto: '영어가 편안해지는 그날까지.' },
  { subject: '영어', name: '조하늘', image: '/images/faculty/eng-조하늘.jpg', motto: '즐겁게 배우면 오래 기억합니다.' },
  { subject: '영어', name: '최용우', image: '/images/faculty/eng-최용우.jpg', motto: '시험에서 흔들리지 않는 실력을 만듭니다.' },
  { subject: '영어', name: '박채원', image: '/images/faculty/eng-박채원.jpg', motto: '학생의 가능성을 끝까지 믿습니다.' },
  // 과학
  { subject: '과학', name: '김응태', image: '/images/faculty/sci-김응태.jpg', motto: '왜 그런지 알면 과학이 쉬워집니다.' },
  { subject: '과학', name: '김현철', image: '/images/faculty/sci-김현철.jpg', motto: '원리를 이해하면 어떤 문제도 풀립니다.' },
  // 국어
  { subject: '국어', name: '고수민', image: '/images/faculty/kor-고수민.jpg', motto: '글을 읽는 힘이 모든 공부의 기초입니다.' },
