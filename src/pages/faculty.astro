---
import Layout from '../components/layout/Layout.astro';

const subjects = ['전체', '수학', '영어', '과학', '국어'];

const faculty = [
  // 수학 (ㄱ~ㅎ)
  { subject: '수학', name: '김경우', image: '/images/faculty/math-김경우.jpg' },
  { subject: '수학', name: '김성환', image: '/images/faculty/math-김성환.jpg' },
  { subject: '수학', name: '나정환', image: '/images/faculty/math-나정환.jpg' },
  { subject: '수학', name: '박명신', image: '/images/faculty/math-박명신.jpg' },
  { subject: '수학', name: '박주원', image: '/images/faculty/math-박주원.jpg' },
  { subject: '수학', name: '이재원', image: '/images/faculty/math-이재원.jpg' },
  { subject: '수학', name: '이희승', image: '/images/faculty/math-이희승.jpg' },
  { subject: '수학', name: '조해공', image: '/images/faculty/math-조해공.jpg' },
  { subject: '수학', name: '함성훈', image: '/images/faculty/math-함성훈.jpg' },
  { subject: '수학', name: '허선영', image: '/images/faculty/math-허선영.jpg' },
  // 영어
  { subject: '영어', name: '양승경', image: '/images/faculty/eng-양승경.jpg' },
  { subject: '영어', name: '양윤정', image: '/images/faculty/eng-양윤정.jpg' },
  { subject: '영어', name: '이소희', image: '/images/faculty/eng-이소희.jpg' },
  { subject: '영어', name: '이정헌', image: '/images/faculty/eng-이정헌.jpg' },
  { subject: '영어', name: '정다운', image: '/images/faculty/eng-정다운.jpg' },
  { subject: '영어', name: '조하늘', image: '/images/faculty/eng-조하늘.jpg' },
  { subject: '영어', name: '최용우', image: '/images/faculty/eng-최용우.jpg' },
  { subject: '영어', name: '박채원', image: '/images/faculty/eng-박채원.jpg' },
  // 과학
  { subject: '과학', name: '김응태', image: '/images/faculty/sci-김응태.jpg' },
  { subject: '과학', name: '김현철', image: '/images/faculty/sci-김현철.jpg' },
  // 국어
  { subject: '국어', name: '고수민', image: '/images/faculty/kor-고수민.jpg' },
  { subject: '국어', name: '석민지', image: '/images/faculty/kor-석민지.jpg' },
];

const subjectColors: Record<string, string> = {
  '수학': 'text-blue-500',
  '영어': 'text-green-500',
  '과학': 'text-orange-500',
  '국어': 'text-brand',
};
---

<Layout title="강사소개 - 대치프라임" description="대치프라임 강사진을 소개합니다.">

  <div class="min-h-screen bg-white">

    <!-- 페이지 타이틀 -->
    <div class="border-b border-gray-200 bg-white">
      <div class="container mx-auto px-4 py-8">
        <h1 class="text-2xl font-bold text-gray-900">강사소개</h1>
      </div>
    </div>

    <!-- 과목 탭 -->
    <div class="sticky top-[65px] z-40 bg-white border-b border-gray-200">
      <div class="container mx-auto px-4">
        <div class="flex overflow-x-auto scrollbar-hide" id="subject-tabs">
          {subjects.map((s) => (
            <button
              data-subject={s}
              class={`subject-tab flex-shrink-0 px-6 py-4 text-sm font-medium border-b-2 transition-colors whitespace-nowrap
                ${s === '전체'
                  ? 'border-gray-900 text-gray-900'
                  : 'border-transparent text-gray-500 hover:text-gray-800'}`}
            >
              {s}
            </button>
          ))}
        </div>
      </div>
    </div>

    <!-- 강사 그리드 -->
    <div class="container mx-auto px-4 py-10">
      <div id="faculty-grid" class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-4xl mx-auto">
        {faculty.map((f) => (
          <div
            class="faculty-card bg-gray-50 rounded-xl overflow-hidden cursor-pointer hover:shadow-md transition-shadow"
            data-subject={f.subject}
          >
            <!-- 강사 이미지 -->
            <div class="relative h-52 bg-gray-200">
              <img
                src={f.image}
                alt={f.name}
                class="w-full h-full object-cover object-top"
                onerror="this.style.display='none'"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/30 via-transparent to-transparent"></div>
            </div>

            <!-- 과목 + 이름 -->
            <div class="px-4 py-3">
              <p class={`text-xs font-semibold mb-0.5 ${subjectColors[f.subject]}`}>{f.subject}</p>
              <p class="text-sm font-bold text-gray-900">{f.name} 선생님</p>
            </div>
          </div>
        ))}
      </div>

      <!-- 데이터 없을 때 -->
      <div id="empty-msg" class="hidden text-center py-20 text-gray-400 text-sm">
        해당 과목 강사 정보를 준비 중입니다.
      </div>
    </div>

  </div>
</Layout>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.subject-tab');
  const cards = document.querySelectorAll<HTMLElement>('.faculty-card');
  const emptyMsg = document.getElementById('empty-msg');
  const grid = document.getElementById('faculty-grid');

  function filter(subject: string) {
    let visible = 0;
    cards.forEach(card => {
      const match = subject === '전체' || card.getAttribute('data-subject') === subject;
      card.style.display = match ? '' : 'none';
      if (match) visible++;
    });
    if (emptyMsg) emptyMsg.classList.toggle('hidden', visible > 0);
  }

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => {
        t.classList.remove('border-gray-900', 'text-gray-900');
        t.classList.add('border-transparent', 'text-gray-500');
      });
      tab.classList.add('border-gray-900', 'text-gray-900');
      tab.classList.remove('border-transparent', 'text-gray-500');
      filter(tab.getAttribute('data-subject') ?? '전체');
    });
  });
</script>

<style>
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
</style>
