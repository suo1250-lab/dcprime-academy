---
import Layout from '../components/layout/Layout.astro';
---

<Layout title="공지사항 - 대치프라임" description="대치프라임 공지사항입니다.">
  <div class="min-h-screen bg-white">
    <div class="container mx-auto px-4 py-12 max-w-4xl">

      <h1 class="text-3xl font-bold text-gray-900 mb-10">공지사항</h1>

      <!-- 테이블 헤더 -->
      <div class="grid grid-cols-[60px_1fr_110px_80px] text-sm text-gray-400 font-medium border-b border-gray-200 pb-3 mb-1 hidden md:grid">
        <span>NO.</span>
        <span>제목</span>
        <span class="text-right">작성일</span>
        <span class="text-right">조회수</span>
      </div>

      <!-- 로딩 -->
      <div id="loading" class="text-center py-24 text-gray-400 text-sm">불러오는 중...</div>

      <!-- 공지 목록 -->
      <ul id="notice-list" class="hidden"></ul>

      <!-- 빈 상태 -->
      <div id="empty-msg" class="hidden text-center py-24 text-gray-400 text-sm">등록된 공지사항이 없습니다.</div>

    </div>
  </div>
</Layout>

<script>
  import { supabase } from '../lib/supabase';

  async function load() {
    const { data, error } = await supabase
      .from('notices')
      .select('id, title, created_at, views')
      .order('created_at', { ascending: false });

    document.getElementById('loading')?.classList.add('hidden');

    if (error || !data || data.length === 0) {
      document.getElementById('empty-msg')?.classList.remove('hidden');
      return;
    }

    const list = document.getElementById('notice-list')!;
    list.classList.remove('hidden');

    list.innerHTML = data.map((n, i) => {
      const no = data.length - i;
      const date = new Date(n.created_at).toLocaleDateString('ko-KR', {
        year: 'numeric', month: '2-digit', day: '2-digit'
      }).replace(/\. /g, '.').replace(/\.$/, '');
      const views = (n.views ?? 0) >= 9999 ? '9,999+' : (n.views ?? 0).toLocaleString();

      return `
        <li>
          <a href="/notice/${n.id}" class="grid md:grid-cols-[60px_1fr_110px_80px] grid-cols-1 items-center py-5 border-b border-gray-100 hover:bg-gray-50 transition-colors gap-y-1 group">
            <span class="text-sm text-gray-400 hidden md:block">${no}</span>
            <span class="text-sm md:text-base font-medium text-gray-800 group-hover:text-brand transition-colors">${escHtml(n.title)}</span>
            <span class="text-sm text-gray-400 md:text-right">${date}</span>
            <span class="text-sm text-gray-400 md:text-right hidden md:block">${views}</span>
          </a>
        </li>
      `;
    }).join('');
  }

  function escHtml(str: string) {
    return String(str ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  document.addEventListener('astro:page-load', load);
</script>
