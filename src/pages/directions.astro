---
import Layout from '../components/layout/Layout.astro';

const branches = [
  {
    name: '능곡관',
    phone: '031-313-0979',
    mapUrl: 'https://naver.me/Grexh0o5',
  },
  {
    name: '장곡관',
    phone: '031-804-2495',
    mapUrl: 'https://naver.me/FvQJ6L7k',
  },
];
---

<Layout title="찾아오시는길 - 대치프라임" description="대치프라임 능곡관·장곡관 위치 안내입니다.">
  <div class="min-h-screen bg-white">

    <div class="border-b border-gray-200">
      <div class="container mx-auto px-4 py-8">
        <h1 class="text-2xl font-bold text-gray-900">찾아오시는길</h1>
      </div>
    </div>

    <div class="container mx-auto px-4 py-12 max-w-3xl space-y-10">
      {branches.map((b) => (
        <div class="rounded-2xl border border-gray-200 overflow-hidden shadow-sm">

          <!-- 헤더 -->
          <div class="bg-brand-light px-6 py-5 flex items-center justify-between flex-wrap gap-3">
            <div>
              <p class="text-xs font-semibold text-brand uppercase tracking-wide mb-0.5">DCPRIME</p>
              <h2 class="text-lg font-bold text-gray-900">대치프라임 {b.name}</h2>
            </div>
            <a href={`tel:${b.phone.replace(/-/g, '')}`}
               class="text-sm font-semibold text-gray-700 hover:text-brand transition-colors">
              📞 {b.phone}
            </a>
          </div>

          <!-- 지도 버튼 영역 -->
          <div class="bg-gray-50 flex flex-col items-center justify-center gap-4 px-6 py-14">
            <div class="text-gray-300">
              <svg class="w-16 h-16 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.2"
                  d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.2"
                  d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <p class="text-sm text-gray-400">아래 버튼을 눌러 지도에서 위치를 확인하세요.</p>
            <a
              href={b.mapUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 bg-[#03C75A] text-white text-sm font-bold px-7 py-3 rounded-xl hover:brightness-95 transition shadow"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
              </svg>
              네이버지도로 보기
            </a>
          </div>

        </div>
      ))}
    </div>

  </div>
</Layout>
