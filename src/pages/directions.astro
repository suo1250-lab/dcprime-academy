---
import Layout from '../components/layout/Layout.astro';

const branches = [
  {
    id: 'neunggok',
    name: '능곡관',
    fullName: '대치프라임학원 (능곡관)',
    subjects: '초등고학년 ~ 고3 | 수학·영어·과학·국어',
    address: '주소를 입력해 주세요',
    phone: '031-313-0979',
    mapUrl: 'https://naver.me/Grexh0o5',
  },
  {
    id: 'janggok',
    name: '장곡관',
    fullName: '대치프라임장곡학원 (장곡관)',
    subjects: '초등고학년 ~ 고3 | 수학·영어·과학·국어',
    address: '주소를 입력해 주세요',
    phone: '031-804-2495',
    mapUrl: 'https://naver.me/FvQJ6L7k',
  },
];
---

<Layout title="찾아오시는길 - 대치프라임" description="대치프라임 능곡관·장곡관 위치 안내입니다.">
  <div class="min-h-screen bg-white">

    <div class="border-b border-gray-200">
      <div class="container mx-auto px-4 py-8">
        <h1 class="text-2xl font-bold text-gray-900">찾아오시는길</h1>
      </div>
    </div>

    <!-- 탭 -->
    <div class="border-b border-gray-200">
      <div class="container mx-auto px-4">
        <div class="flex">
          {branches.map((b, i) => (
            <button
              data-tab={b.id}
              class={`tab-btn px-8 py-4 text-sm font-semibold border-b-2 transition-colors whitespace-nowrap
                ${i === 0 ? 'border-brand text-brand' : 'border-transparent text-gray-400 hover:text-gray-700'}`}
            >
              {b.name} 찾아오기
            </button>
          ))}
        </div>
      </div>
    </div>

    <!-- 탭 패널 -->
    {branches.map((b, i) => (
      <div id={`panel-${b.id}`} class={`tab-panel ${i !== 0 ? 'hidden' : ''}`}>

        <!-- 지도 영역 (카카오맵 API 연동 전 플레이스홀더) -->
        <div
          id={`map-${b.id}`}
          class="w-full bg-gray-100 flex items-center justify-center"
          style="height: 420px;"
          data-lat={b.lat}
          data-lng={b.lng}
          data-name={b.name}
        >
          <div class="text-center text-gray-400">
            <svg class="w-12 h-12 mx-auto mb-3 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                d="M17.657 16.657L13.414 20.9a2 2 0 01-2.828 0l-4.243-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <p class="text-sm">지도 준비 중</p>
          </div>
        </div>

        <!-- 관 안내 -->
        <div class="container mx-auto px-4 pt-10 max-w-4xl">
          <div class="bg-brand-light rounded-2xl p-6 mb-8">
            <p class="text-xs font-semibold text-brand uppercase tracking-wide mb-1">DCPRIME</p>
            <h2 class="text-lg font-bold text-gray-900 mb-1">{b.fullName}</h2>
            <p class="text-sm text-gray-500">{b.subjects}</p>
          </div>
        </div>

        <!-- 주소 / 전화 카드 -->
        <div class="container mx-auto px-4 pb-10 max-w-4xl">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-10">

            <div class="border border-gray-200 rounded-2xl p-6 flex flex-col items-center text-center gap-3">
              <div class="w-14 h-14 rounded-full bg-brand-light flex items-center justify-center">
                <svg class="w-6 h-6 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
                    d="M17.657 16.657L13.414 20.9a2 2 0 01-2.828 0l-4.243-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <p class="text-sm font-bold text-gray-800">주소</p>
              <p class="text-sm text-gray-500">{b.address}</p>
            </div>

            <div class="border border-gray-200 rounded-2xl p-6 flex flex-col items-center text-center gap-3">
              <div class="w-14 h-14 rounded-full bg-brand-light flex items-center justify-center">
                <svg class="w-6 h-6 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
              </div>
              <p class="text-sm font-bold text-gray-800">전화번호</p>
              <a href={`tel:${b.phone.replace(/-/g, '')}`} class="text-sm text-gray-500 hover:text-brand transition-colors">{b.phone}</a>
            </div>

          </div>

          <!-- 네이버지도 바로가기 -->
          <div class="text-center">
            <a href={b.mapUrl} target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center gap-2 bg-[#03C75A] text-white text-sm font-bold px-6 py-3 rounded-xl hover:brightness-95 transition shadow-sm">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
              </svg>
              네이버지도로 보기
            </a>
          </div>
        </div>

      </div>
    ))}

  </div>
</Layout>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
  const panels = document.querySelectorAll<HTMLElement>('.tab-panel');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => {
        t.classList.remove('border-brand', 'text-brand');
        t.classList.add('border-transparent', 'text-gray-400');
      });
      tab.classList.add('border-brand', 'text-brand');
      tab.classList.remove('border-transparent', 'text-gray-400');

      const target = tab.dataset.tab;
      panels.forEach(p => p.classList.add('hidden'));
      document.getElementById(`panel-${target}`)?.classList.remove('hidden');
    });
  });
</script>
