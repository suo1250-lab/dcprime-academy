---
import Layout from '../components/layout/Layout.astro';
---

<Layout title="관 안내 - 대치프라임" description="대치프라임 능곡관·장곡관을 안내합니다.">
  <div class="container mx-auto px-4 py-16 min-h-screen">
    <h1 class="text-3xl font-bold text-gray-900 mb-8">관 안내</h1>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <div class="bg-white rounded-xl shadow-md p-6 border border-gray-100">
        <h2 class="text-xl font-bold text-gray-900 mb-2">대치프라임학원 (능곡관)</h2>
        <p class="text-gray-500 text-sm mb-4">초등고학년 ~ 고3 | 수학·영어·과학·국어</p>
        <p class="text-gray-700 mb-1">📞 <a href="tel:031-313-0979" class="hover:text-brand transition-colors font-medium">031.313.0979</a></p>
      </div>
      <div class="bg-white rounded-xl shadow-md p-6 border border-gray-100">
        <h2 class="text-xl font-bold text-gray-900 mb-2">대치프라임장곡학원 (장곡관)</h2>
        <p class="text-gray-500 text-sm mb-4">초등고학년 ~ 고3 | 수학·영어·과학·국어</p>
        <p class="text-gray-700 mb-1">📞 <a href="tel:031-804-24950" class="hover:text-brand transition-colors font-medium">031.8042.4950</a></p>
      </div>
    </div>
  </div>
</Layout>
