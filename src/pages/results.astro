---
import Layout from '../components/layout/Layout.astro';
---

<Layout title="명예의 전당 - 대치프라임" description="대치프라임 합격자 명예의 전당입니다.">
  <div class="min-h-screen bg-white">

    <div class="py-14 text-center border-b border-gray-100">
      <h1 class="text-4xl font-bold text-gray-900">명예의 전당</h1>
    </div>

    <div class="container mx-auto px-4 py-8 max-w-5xl">
      <div id="loading" class="text-center py-24 text-gray-400 text-sm">불러오는 중...</div>
      <div id="year-tabs" class="hidden mb-10"></div>
      <div id="table-area"></div>
    </div>

  </div>
</Layout>

<script>
  import { supabase } from '../lib/supabase';

  async function load() {
    const { data, error } = await supabase
      .from('results')
      .select('*')
      .order('id', { ascending: true });

    document.getElementById('loading')?.classList.add('hidden');

    if (error || !data || data.length === 0) {
      document.getElementById('table-area')!.innerHTML =
        '<p class="text-center text-gray-400 py-20 text-sm">데이터를 준비 중입니다.</p>';
      return;
    }

    // 연도 추출 (내림차순)
    const years = [...new Set(data.map(r => r.year))].sort((a, b) => b.localeCompare(a));

    // 연도별 그룹 { year: { 대입: [], 고입: [] } }
    const grouped: Record<string, Record<string, typeof data>> = {};
    data.forEach(r => {
      if (!grouped[r.year]) grouped[r.year] = {};
      if (!grouped[r.year][r.category]) grouped[r.year][r.category] = [];
      grouped[r.year][r.category].push(r);
    });

    // 탭 렌더
    const tabsEl = document.getElementById('year-tabs')!;
    tabsEl.className = 'grid grid-cols-3 sm:grid-cols-6 border border-gray-200 rounded-sm overflow-hidden mb-10';
    tabsEl.innerHTML = years.map((y, i) => `
      <button data-year="${y}" class="year-tab py-3 text-sm font-medium border-b border-r border-gray-200 transition-colors
        ${i === 0 ? 'bg-brand text-white' : 'bg-white text-gray-500 hover:bg-gray-50'}">
        ${y}
      </button>
    `).join('');

    // 패널 렌더
    const areaEl = document.getElementById('table-area')!;
    areaEl.innerHTML = years.map((y, i) => {
      const cats = grouped[y];
      const sections = Object.keys(cats).sort(); // 고입, 대입 순
      return `
        <div data-panel="${y}" class="year-panel ${i !== 0 ? 'hidden' : ''}">
          ${sections.map(cat => {
            const rows = cats[cat];
            const half = Math.ceil(rows.length / 2);
            const isDaip = cat === '대입';
            return `
              <h3 class="text-base font-bold text-gray-800 mb-4 ${cat !== sections[0] ? 'mt-10' : ''}">${y} ${cat}</h3>
              <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-2">
                ${[rows.slice(0, half), rows.slice(half)].map(group => `
                  <table class="w-full text-sm border-t-2 border-gray-800">
                    <thead>
                      <tr class="border-b border-gray-200">
                        <th class="py-3 px-3 text-center font-semibold text-gray-700">${isDaip ? '학교' : '합격 고교'}</th>
                        <th class="py-3 px-3 text-center font-semibold text-gray-700">이름</th>
                        <th class="py-3 px-3 text-center font-semibold text-gray-700">${isDaip ? '대학' : '출신 학교'}</th>
                        ${isDaip ? '<th class="py-3 px-3 text-center font-semibold text-gray-700">학과</th>' : ''}
                      </tr>
                    </thead>
                    <tbody>
                      ${group.map(r => `
                        <tr class="border-b border-gray-100 hover:bg-gray-50">
                          <td class="py-3 px-3 text-center text-gray-600">${esc(r.school)}</td>
                          <td class="py-3 px-3 text-center text-gray-600">${esc(r.name)}</td>
                          <td class="py-3 px-3 text-center text-gray-700 font-medium">${esc(r.university)}</td>
                          ${isDaip ? `<td class="py-3 px-3 text-center text-gray-600">${esc(r.dept ?? '')}</td>` : ''}
                        </tr>
                      `).join('')}
                    </tbody>
                  </table>
                `).join('')}
              </div>
            `;
          }).join('')}
        </div>
      `;
    }).join('');

    // 탭 이벤트
    tabsEl.querySelectorAll<HTMLButtonElement>('.year-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        tabsEl.querySelectorAll('.year-tab').forEach(t => {
          t.classList.remove('bg-brand', 'text-white');
          t.classList.add('bg-white', 'text-gray-500');
        });
        tab.classList.add('bg-brand', 'text-white');
        tab.classList.remove('bg-white', 'text-gray-500');
        areaEl.querySelectorAll<HTMLElement>('.year-panel').forEach(p => p.classList.add('hidden'));
        areaEl.querySelector(`[data-panel="${tab.dataset.year}"]`)?.classList.remove('hidden');
      });
    });
  }

  function esc(str: string) {
    return String(str ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  document.addEventListener('astro:page-load', load);
</script>
