---
import Layout from '../components/layout/Layout.astro';

const sections = [
  { id: 'greeting', label: '인사말' },
  { id: 'history',  label: '학원 연혁' },
  { id: 'features', label: '학원 특징' },
];
---

<Layout title="학원소개 - 대치프라임" description="대치프라임학원을 소개합니다.">
  <div class="min-h-screen bg-white">

    <div class="border-b border-gray-200">
      <div class="container mx-auto px-4 py-8">
        <h1 class="text-2xl font-bold text-gray-900">학원소개</h1>
      </div>
    </div>

    <!-- 탭 -->
    <div class="sticky top-[65px] z-40 bg-white border-b border-gray-200">
      <div class="container mx-auto px-4">
        <div class="flex">
          {sections.map((s, i) => (
            <button
              data-tab={s.id}
              class={`about-tab px-6 py-4 text-sm font-medium border-b-2 transition-colors whitespace-nowrap
                ${i === 0 ? 'border-brand text-brand' : 'border-transparent text-gray-400 hover:text-gray-700'}`}
            >
              {s.label}
            </button>
          ))}
        </div>
      </div>
    </div>

    <div class="container mx-auto px-4 py-16 max-w-3xl">

      <!-- 인사말 -->
      <div id="panel-greeting" class="about-panel">
        <h2 class="text-2xl font-bold text-gray-900 mb-8">인사말</h2>
        <div class="bg-gray-50 rounded-2xl p-10 text-center text-gray-400 text-sm">
          추후 업데이트 예정입니다.
        </div>
      </div>

      <!-- 학원 연혁 -->
      <div id="panel-history" class="about-panel hidden">
        <h2 class="text-2xl font-bold text-gray-900 mb-8">학원 연혁</h2>
        <div class="bg-gray-50 rounded-2xl p-10 text-center text-gray-400 text-sm">
          추후 업데이트 예정입니다.
        </div>
      </div>

      <!-- 학원 특징 -->
      <div id="panel-features" class="about-panel hidden">
        <h2 class="text-2xl font-bold text-gray-900 mb-10">학원 특징</h2>

        <!-- 10원칙 -->
        <h3 class="text-lg font-bold text-gray-900 mb-5">대치프라임 10가지 교육 원칙</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-14">
          {[
            ['01', '개념 우선', '암기보다 원리 이해를 먼저 다집니다.'],
            ['02', '맞춤 지도', '학생 수준에 맞는 1:1 개별 관리.'],
            ['03', '자기주도', '스스로 생각하는 힘을 길러줍니다.'],
            ['04', '반복 훈련', '완성될 때까지 반복하고 점검합니다.'],
            ['05', '오답 분석', '틀린 이유를 찾아야 진짜 실력이 됩니다.'],
            ['06', '입시 전략', '목표 대학 역산 설계로 방향을 잡습니다.'],
            ['07', '강사 전문성', '과목별 검증된 최고 강사진이 함께합니다.'],
            ['08', '소수 정예', '집중력 있는 수업 환경을 보장합니다.'],
            ['09', '밀착 관리', '학부모와의 소통으로 빈틈을 없앱니다.'],
            ['10', '지속 성장', '매달 실력을 점검하고 성장을 확인합니다.'],
          ].map(([no, title, desc]) => (
            <div class="flex gap-4 bg-gray-50 rounded-xl p-4 border border-gray-100">
              <span class="text-xl font-black text-brand opacity-30 leading-none mt-0.5 w-8 flex-shrink-0">{no}</span>
              <div>
                <p class="text-sm font-bold text-gray-900 mb-1">{title}</p>
                <p class="text-xs text-gray-500 leading-relaxed">{desc}</p>
              </div>
            </div>
          ))}
        </div>


      </div>

    </div>
  </div>
</Layout>

<script>
  function init() {
    const tabs = document.querySelectorAll<HTMLButtonElement>('.about-tab');
    const panels = document.querySelectorAll<HTMLElement>('.about-panel');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => {
          t.classList.remove('border-brand', 'text-brand');
          t.classList.add('border-transparent', 'text-gray-400');
        });
        tab.classList.add('border-brand', 'text-brand');
        tab.classList.remove('border-transparent', 'text-gray-400');

        panels.forEach(p => p.classList.add('hidden'));
        document.getElementById(`panel-${tab.dataset.tab}`)?.classList.remove('hidden');
      });
    });
  }

  document.addEventListener('astro:page-load', init);
</script>
