---
---

<section class="relative h-screen flex items-center justify-center overflow-hidden">
  <!-- 배경 이미지 슬라이더 -->
  <div class="absolute inset-0">
    <img src="/images/hero-bg.jpg" alt="대치프라임" class="w-full h-full object-cover" />
    <div class="absolute inset-0 bg-black/55"></div>
  </div>

  <!-- 콘텐츠 -->
  <div class="relative z-10 text-center text-white px-4">
    <p class="text-sm md:text-lg tracking-widest mb-4 text-gray-300 animate-fade-in-up">
      DC PRIME ACADEMY
    </p>
    <h1 class="text-3xl md:text-6xl font-bold mb-4 leading-tight animate-fade-in-up delay-100">
      대치프라임
    </h1>
    <p class="text-base md:text-xl text-gray-200 mb-8 animate-fade-in-up delay-200">
      교육과 미래를 디자인하는
    </p>
    <a href="/inquiry"
      class="inline-block border-2 border-white text-white text-sm md:text-base font-semibold px-8 md:px-10 py-3 rounded-full hover:bg-white hover:text-gray-900 transition-all duration-300 animate-fade-in-up delay-300">
      자세히 보기
    </a>
  </div>

  <!-- 슬라이드 닷 -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex gap-2 z-10">
    <span class="w-2.5 h-2.5 rounded-full bg-white opacity-100 inline-block"></span>
    <span class="w-2.5 h-2.5 rounded-full bg-white opacity-40 inline-block"></span>
    <span class="w-2.5 h-2.5 rounded-full bg-white opacity-40 inline-block"></span>
  </div>
</section>

<style>
  @keyframes fade-in-up {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in-up {
    animation: fade-in-up 0.7s ease-out forwards;
    opacity: 0;
  }
  .delay-100 { animation-delay: 0.1s; }
  .delay-200 { animation-delay: 0.2s; }
  .delay-300 { animation-delay: 0.3s; }
</style>
