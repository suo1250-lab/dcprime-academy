---
const slides = [
  { image: '/images/hero-bg.jpg',    subtitle: '교육과 미래를 디자인하는' },
  { image: '/images/hero-bg-2.jpg',  subtitle: '최고의 강사진과 함께하는' },
  { image: '/images/hero-bg-3.jpg',  subtitle: '능곡관 · 장곡관' },
];
---

<section class="relative h-screen overflow-hidden">

  <!-- 슬라이드 -->
  {slides.map((s, i) => (
    <div
      class={`slide absolute inset-0 transition-opacity duration-700 ${i === 0 ? 'opacity-100' : 'opacity-0'}`}
      data-index={i}
    >
      <img src={s.image} alt="대치프라임" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-black/55"></div>
      <div class="absolute inset-0 flex flex-col items-center justify-center text-white text-center px-4">
        <p class="text-sm md:text-lg tracking-widest mb-4 text-gray-300">DC PRIME ACADEMY</p>
        <h1 class="text-3xl md:text-6xl font-bold mb-4 leading-tight">대치프라임</h1>
        <p class="text-base md:text-xl text-gray-200 mb-8">{s.subtitle}</p>
        <a href="/inquiry"
          class="inline-block border-2 border-white text-white text-sm md:text-base font-semibold px-8 md:px-10 py-3 rounded-full hover:bg-white hover:text-gray-900 transition-all duration-300">
          상담 신청
        </a>
      </div>
    </div>
  ))}

  <!-- 닷 네비게이션 -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex gap-2.5 z-10">
    {slides.map((_, i) => (
      <button
        class={`dot w-2.5 h-2.5 rounded-full transition-all duration-300 ${i === 0 ? 'bg-white scale-125' : 'bg-white/40'}`}
        data-dot={i}
        aria-label={`슬라이드 ${i + 1}`}
      />
    ))}
  </div>

</section>

<script>
  const slides = document.querySelectorAll<HTMLElement>('.slide');
  const dots = document.querySelectorAll<HTMLButtonElement>('.dot');
  let current = 0;
  let timer: ReturnType<typeof setInterval>;

  function goTo(index: number) {
    slides[current].classList.replace('opacity-100', 'opacity-0');
    dots[current].classList.remove('bg-white', 'scale-125');
    dots[current].classList.add('bg-white/40');

    current = index;

    slides[current].classList.replace('opacity-0', 'opacity-100');
    dots[current].classList.add('bg-white', 'scale-125');
    dots[current].classList.remove('bg-white/40');
  }

  function next() {
    goTo((current + 1) % slides.length);
  }

  dots.forEach(dot => {
    dot.addEventListener('click', () => {
      clearInterval(timer);
      goTo(Number(dot.dataset.dot));
      timer = setInterval(next, 4000);
    });
  });

  timer = setInterval(next, 4000);
</script>
