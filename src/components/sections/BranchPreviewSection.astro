---
import SectionTitle from '../ui/SectionTitle.astro';
---

<section class="py-16 md:py-24 bg-gray-50">
  <div class="container mx-auto px-4">
    <SectionTitle
      title="가까운 곳에서 만나는 대치프라임"
      subtitle="능곡관 & 장곡관"
    />

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 mt-10">
      <!-- 능곡관 -->
      <div class="bg-white rounded-xl shadow-md overflow-hidden">
        <img src="/images/branch-neunggok.jpg" alt="능곡관 전경" class="w-full h-40 md:h-56 object-cover" />
        <div class="p-6">
          <h3 class="text-xl font-bold text-gray-900 mb-1">대치프라임학원 (능곡관)</h3>
          <p class="text-gray-500 text-sm mb-4">초등고학년 ~ 고3 | 수학·영어·과학·국어</p>
          <div class="flex flex-col gap-2 text-sm text-gray-600 mb-6">
            <p>📞 <a href="tel:031-313-0979" class="hover:text-brand transition-colors font-medium">031.313.0979</a></p>
          </div>
          <div class="flex gap-3">
            <a href="/inquiry" class="flex-1 text-center bg-brand text-white text-sm font-semibold py-2.5 rounded-md hover:brightness-95 transition-all">
              상담 신청
            </a>
            <a href="tel:031-313-0979" class="flex-1 text-center border border-gray-300 text-gray-700 text-sm font-semibold py-2.5 rounded-md hover:bg-gray-50 transition-all">
              전화 문의
            </a>
          </div>
        </div>
      </div>

      <!-- 장곡관 -->
      <div class="bg-white rounded-xl shadow-md overflow-hidden">
        <img src="/images/branch-janggok.jpg" alt="장곡관 전경" class="w-full h-40 md:h-56 object-cover" />
        <div class="p-6">
          <h3 class="text-xl font-bold text-gray-900 mb-1">대치프라임장곡학원 (장곡관)</h3>
          <p class="text-gray-500 text-sm mb-4">초등고학년 ~ 고3 | 수학·영어·과학·국어</p>
          <div class="flex flex-col gap-2 text-sm text-gray-600 mb-6">
            <p>📞 <a href="tel:031-804-24950" class="hover:text-brand transition-colors font-medium">031.8042.4950</a></p>
          </div>
          <div class="flex gap-3">
            <a href="/inquiry" class="flex-1 text-center bg-brand text-white text-sm font-semibold py-2.5 rounded-md hover:brightness-95 transition-all">
              상담 신청
            </a>
            <a href="tel:031-804-24950" class="flex-1 text-center border border-gray-300 text-gray-700 text-sm font-semibold py-2.5 rounded-md hover:bg-gray-50 transition-all">
              전화 문의
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
