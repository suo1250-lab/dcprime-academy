---
import SectionTitle from '../ui/SectionTitle.astro';
---

<section class="py-16 md:py-24 bg-gray-50">
  <div class="container mx-auto px-4">
    <SectionTitle
      title="결과로 증명하는 강사진"
      subtitle="강사소개"
    />
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="bg-white rounded-xl shadow-sm p-6 text-center border border-gray-100">
        <img src="/images/faculty-placeholder-1.jpg" alt="강사" class="w-24 h-24 rounded-full mx-auto mb-4 object-cover" />
        <h3 class="text-base font-bold text-gray-900 mb-1">수학 전문 강사</h3>
        <p class="text-sm text-brand mb-2">수학 킬러 문항 전문</p>
        <p class="text-sm text-gray-500">내용 준비 중</p>
      </div>
      <div class="bg-white rounded-xl shadow-sm p-6 text-center border border-gray-100">
        <img src="/images/faculty-placeholder-2.jpg" alt="강사" class="w-24 h-24 rounded-full mx-auto mb-4 object-cover" />
        <h3 class="text-base font-bold text-gray-900 mb-1">국어 전문 강사</h3>
        <p class="text-sm text-brand mb-2">국어 비문학 전문</p>
        <p class="text-sm text-gray-500">내용 준비 중</p>
      </div>
      <div class="bg-white rounded-xl shadow-sm p-6 text-center border border-gray-100">
        <img src="/images/faculty-placeholder-3.jpg" alt="강사" class="w-24 h-24 rounded-full mx-auto mb-4 object-cover" />
        <h3 class="text-base font-bold text-gray-900 mb-1">영어 전문 강사</h3>
        <p class="text-sm text-brand mb-2">영어 절대평가 전문</p>
        <p class="text-sm text-gray-500">내용 준비 중</p>
      </div>
    </div>
    <div class="text-center mt-8">
      <a href="/faculty" class="inline-block border border-gray-300 text-gray-700 text-sm font-semibold px-6 py-2.5 rounded-lg hover:bg-gray-50 transition-all">
        강사진 전체 보기
      </a>
    </div>
  </div>
</section>
