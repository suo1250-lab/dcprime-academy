---
interface Props {
  title: string;
  subtitle?: string;
}
const { title, subtitle } = Astro.props;
---

<div class="text-center mb-8 md:mb-12 px-4">
  {subtitle && <p class="text-brand text-base font-semibold mb-2">{subtitle}</p>}
  <h2 class="text-2xl md:text-3xl font-bold text-gray-900 leading-tight">{title}</h2>
</div>
