---
// src/components/forms/InquiryForm.astro
import Button from '../ui/Button.astro';
---

<div class="bg-primary-dark-base p-8 rounded-lg shadow-xl border border-secondary-light-gray/20">
  <form id="inquiryForm" class="space-y-6">
    <!-- Step 1: Diagnostic Teaser & Initial Contact -->
    <div id="step1" class="space-y-6">
      <h3 class="text-xl font-semibold text-neutral-white mb-4">자녀의 학습 고민, 1분 진단으로 해결의 실마리를 찾으세요!</h3>
      
      <!-- Diagnostic Teaser Questions -->
      <div>
        <label for="grade" class="block text-secondary-light-gray text-sm font-bold mb-2">1. 자녀의 현재 학년은?</label>
        <select id="grade" name="grade" class="shadow appearance-none border rounded w-full py-3 px-4 text-primary-dark-base leading-tight focus:outline-none focus:shadow-outline bg-neutral-white" required>
          <option value="">선택하세요</option>
          <option value="초등">초등</option>
          <option value="중1">중1</option>
          <option value="중2">중2</option>
          <option value="중3">중3</option>
          <option value="고1">고1</option>
          <option value="고2">고2</option>
          <option value="고3">고3</option>
        </select>
      </div>

      <div>
        <label for="subject" class="block text-secondary-light-gray text-sm font-bold mb-2">2. 가장 고민되는 과목은?</label>
        <select id="subject" name="subject" class="shadow appearance-none border rounded w-full py-3 px-4 text-primary-dark-base leading-tight focus:outline-none focus:shadow-outline bg-neutral-white" required>
          <option value="">선택하세요</option>
          <option value="국어">국어</option>
          <option value="영어">영어</option>
          <option value="수학">수학</option>
          <option value="과학">과학</option>
          <option value="기타">기타</option>
        </select>
      </div>

      <div>
        <label for="concern" class="block text-secondary-light-gray text-sm font-bold mb-2">3. 주요 학습 고민은?</label>
        <select id="concern" name="concern" class="shadow appearance-none border rounded w-full py-3 px-4 text-primary-dark-base leading-tight focus:outline-none focus:shadow-outline bg-neutral-white" required>
          <option value="">선택하세요</option>
          <option value="성적 부진">성적 부진</option>
          <option value="학습 습관 부족">학습 습관 부족</option>
          <option value="동기 부족">동기 부족</option>
          <option value="입시 정보 부족">입시 정보 부족</option>
          <option value="체계적 관리 부족">체계적 관리 부족</option>
          <option value="기타">기타</option>
        </select>
      </div>

      <!-- Initial Contact Fields -->
      <div>
        <label for="parentName" class="block text-secondary-light-gray text-sm font-bold mb-2">학부모님 성함</label>
        <input type="text" id="parentName" name="parentName" class="shadow appearance-none border rounded w-full py-3 px-4 text-primary-dark-base leading-tight focus:outline-none focus:shadow-outline bg-neutral-white" placeholder="성함을 입력해주세요" required>
      </div>

      <div>
        <label for="phoneNumber" class="block text-secondary-light-gray text-sm font-bold mb-2">연락처</label>
        <input type="tel" id="phoneNumber" name="phoneNumber" class="shadow appearance-none border rounded w-full py-3 px-4 text-primary-dark-base leading-tight focus:outline-none focus:shadow-outline bg-neutral-white" placeholder="휴대폰 번호를 입력해주세요 (예: 010-1234-5678)" required>
      </div>

      <p class="text-secondary-medium-gray text-sm text-center">
        개인 정보는 상담 목적으로만 활용되며, 어떤 비용이나 의무도 발생하지 않습니다.
      </p>

      <Button type="submit" variant="primary" size="large" class="w-full">
        다음 단계로 이동 (무료 분석 결과 받기)
      </Button>
    </div>

    <!-- Step 2: Post-Submission Confirmation & Next Actions -->
    <div id="step2" class="hidden text-center space-y-6">
      <h3 class="text-xl font-semibold text-neutral-white mb-4">무료 성적 분석 & 전략 리포트 신청이 완료되었습니다!</h3>
      <p class="text-lg text-secondary-light-gray mb-4">
        신청해 주셔서 감사합니다. 대치프라임 전문 컨설턴트가 24시간 내에 기재해 주신 연락처로 분석 결과와 함께 연락드릴 예정입니다.
      </p>
      <p class="text-brand font-semibold mb-4">
        (오늘 신청하셨으므로, 내일까지 결과를 받아보실 수 있습니다.)
      </p>
      <p class="text-secondary-medium-gray text-sm mb-8">
        (대치프라임은 10,000건 이상의 상담 노하우와 98%의 고객 만족도를 자랑합니다.)
      </p>

      <div class="space-y-4">
        <Button href="/results" variant="secondary" size="medium" class="w-full">
          대치프라임 합격/성적 실적 더 보기
        </Button>
        <Button href="/faculty" variant="secondary" size="medium" class="w-full">
          대치프라임 강사진 프로필 확인하기
        </Button>
        <a href="https://pf.kakao.com/_YOUR_KAKAOTALK_ID" target="_blank" rel="noopener noreferrer" class="block">
          <Button variant="secondary" size="medium" class="w-full">카카오톡 채널 추가하고 실시간 소식 받기</Button>
        </a>
        <a href="tel:000-0000-0000" class="block">
          <Button variant="secondary" size="medium" class="w-full">궁금한 점이 있으신가요? 바로 전화 문의하기</Button>
        </a>
      </div>

      <div class="mt-8 pt-6 border-t border-secondary-light-gray/20 space-y-4">
        <p class="text-neutral-white text-lg font-semibold">더 정확한 분석을 위해 추가 정보를 입력해 주세요 (선택 사항)</p>
        <div>
          <label for="studentName" class="block text-secondary-light-gray text-sm font-bold mb-2">자녀 이름</label>
          <input type="text" id="studentName" name="studentName" class="shadow appearance-none border rounded w-full py-3 px-4 text-primary-dark-base leading-tight focus:outline-none focus:shadow-outline bg-neutral-white" placeholder="자녀 이름을 입력해주세요">
        </div>
        <div>
          <label for="preferredBranch" class="block text-secondary-light-gray text-sm font-bold mb-2">희망 상담 관</label>
          <select id="preferredBranch" name="preferredBranch" class="shadow appearance-none border rounded w-full py-3 px-4 text-primary-dark-base leading-tight focus:outline-none focus:shadow-outline bg-neutral-white">
            <option value="">선택하세요</option>
            <option value="능곡관">능곡관</option>
            <option value="장곡관">장곡관</option>
          </select>
        </div>
        <div>
          <label for="inquiryDetails" class="block text-secondary-light-gray text-sm font-bold mb-2">구체적인 상담 내용</label>
          <textarea id="inquiryDetails" name="inquiryDetails" rows="4" class="shadow appearance-none border rounded w-full py-3 px-4 text-primary-dark-base leading-tight focus:outline-none focus:shadow-outline bg-neutral-white" placeholder="궁금한 점이나 특별히 상담받고 싶은 내용을 입력해주세요"></textarea>
        </div>
        <Button type="button" variant="primary" size="medium" class="w-full" onClick="alert('추가 정보가 제출되었습니다. 감사합니다!');">
          추가 정보 제출
        </Button>
      </div>
    </div>
  </form>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('inquiryForm');
    const step1 = document.getElementById('step1');
    const step2 = document.getElementById('step2');

    if (form && step1 && step2) {
      form.addEventListener('submit', (event) => {
        event.preventDefault(); // Prevent default form submission

        // Basic validation for Step 1 required fields
        const grade = document.getElementById('grade');
        const subject = document.getElementById('subject');
        const concern = document.getElementById('concern');
        const parentName = document.getElementById('parentName');
        const phoneNumber = document.getElementById('phoneNumber');

        if (!grade.value || !subject.value || !concern.value || !parentName.value || !phoneNumber.value) {
          alert('필수 정보를 모두 입력해주세요.');
          return;
        }

        // Simulate form submission (e.g., send data to an API or external service)
        console.log('Form Step 1 Data:', {
          grade: grade.value,
          subject: subject.value,
          concern: concern.value,
          parentName: parentName.value,
          phoneNumber: phoneNumber.value,
        });

        // Transition to Step 2
        step1.classList.add('hidden');
        step2.classList.remove('hidden');

        // Scroll to top for better UX
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }
  });
</script>
