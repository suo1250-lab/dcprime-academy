---
---

<header class="bg-white border-b border-[#e0e2ed] sticky top-0 z-50">
  <nav class="container mx-auto flex items-center justify-between px-4 py-3">

    <!-- 로고 -->
    <a href="/" class="flex-shrink-0">
      <img src="/favicon-circle.png" alt="대치프라임" class="h-12 w-12 object-cover" />
    </a>

    <!-- 메뉴 (PC) -->
    <ul class="hidden md:flex items-center gap-7 text-sm font-medium text-gray-700">
      <li><a href="/about" class="hover:text-brand transition-colors">학원소개</a></li>
      <li><a href="/curriculum" class="hover:text-brand transition-colors">커리큘럼</a></li>
      <li><a href="/faculty" class="hover:text-brand transition-colors">강사소개</a></li>
      <li><a href="/results" class="hover:text-brand transition-colors">명예의 전당</a></li>
      <li><a href="/notice" class="hover:text-brand transition-colors">공지사항</a></li>
      <li><a href="/inquiry" class="hover:text-brand transition-colors">상담 신청</a></li>
      <!-- 오시는길 드롭다운 -->
      <li class="relative group">
        <button class="hover:text-brand transition-colors flex items-center gap-1">
          오시는길
          <svg class="w-3 h-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>
        <ul class="absolute top-full left-1/2 -translate-x-1/2 mt-2 bg-white border border-gray-200 rounded-xl shadow-lg overflow-hidden opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 w-32">
          <li><a href="/directions#neunggok" class="block px-4 py-3 text-sm text-gray-700 hover:bg-brand-light hover:text-brand transition-colors text-center">능곡관</a></li>
          <li><a href="/directions#janggok" class="block px-4 py-3 text-sm text-gray-700 hover:bg-brand-light hover:text-brand transition-colors border-t border-gray-100 text-center">장곡관</a></li>
        </ul>
      </li>
    </ul>

    <!-- SNS 아이콘 (PC) -->
    <div class="hidden md:flex items-center gap-2">
      <!-- 블로그 -->
      <a href="https://blog.naver.com/dcprime" target="_blank" rel="noopener noreferrer" class="w-11 h-11 rounded-full border-2 border-gray-300 flex items-center justify-center hover:border-brand transition-colors" aria-label="네이버 블로그">
        <span class="text-green-600 font-bold text-sm">N</span>
      </a>
      <!-- 전화 -->
      <a href="tel:031-313-0979" class="w-11 h-11 rounded-full border-2 border-gray-300 flex items-center justify-center hover:border-brand transition-colors" aria-label="전화 문의">
        <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
      </a>
      <!-- 카카오톡 -->
      <a href="#" target="_blank" rel="noopener noreferrer" class="w-11 h-11 rounded-full border-2 border-gray-300 flex items-center justify-center hover:border-brand transition-colors" aria-label="카카오톡">
        <svg class="w-5 h-5 text-gray-600" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 3C6.477 3 2 6.477 2 10.8c0 2.7 1.6 5.1 4 6.6l-.8 3 3.4-2.1c1 .2 2 .3 1.4.3 5.523 0 10-3.477 10-7.8S17.523 3 12 3z"/>
        </svg>
      </a>
      <!-- 인스타그램 -->
      <a href="https://www.instagram.com/dcprim_sh/" target="_blank" rel="noopener noreferrer" class="w-11 h-11 rounded-full border-2 border-gray-300 flex items-center justify-center hover:border-brand transition-colors" aria-label="인스타그램">
        <svg class="w-5 h-5 text-gray-600" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
        </svg>
      </a>
    </div>

    <!-- 햄버거 (모바일) -->
    <button id="mobile-menu-btn" class="md:hidden text-gray-700 focus:outline-none flex items-center justify-center w-12 h-12 -mr-2 rounded-xl active:bg-gray-100" aria-label="메뉴">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </nav>

  <!-- 모바일 메뉴 -->
  <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-gray-100 px-4 pb-4">
    <ul class="flex flex-col gap-3 text-sm font-medium text-gray-700 pt-3">
      <li><a href="/about" class="block py-1 hover:text-brand">학원소개</a></li>
      <li><a href="/curriculum" class="block py-1 hover:text-brand">커리큘럼</a></li>
      <li><a href="/faculty" class="block py-1 hover:text-brand">강사소개</a></li>
      <li><a href="/results" class="block py-1 hover:text-brand">명예의 전당</a></li>
      <li><a href="/notice" class="block py-1 hover:text-brand">공지사항</a></li>
      <li><a href="/inquiry" class="block py-1 hover:text-brand">상담 신청</a></li>
      <li>
        <span class="block py-1 text-gray-500">오시는길</span>
        <ul class="ml-4 mt-1 flex flex-col gap-1">
          <li><a href="/directions#neunggok" class="block py-1 text-gray-500 hover:text-brand">능곡관</a></li>
          <li><a href="/directions#janggok" class="block py-1 text-gray-500 hover:text-brand">장곡관</a></li>
        </ul>
      </li>
    </ul>
  </div>
</header>

<script>
  function initMenu() {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    if (!btn || !menu) return;
    btn.addEventListener('click', () => menu.classList.toggle('hidden'));
    // 메뉴 링크 클릭 시 자동 닫기
    menu.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => menu.classList.add('hidden'));
    });
  }
  document.addEventListener('astro:page-load', initMenu);
</script>
